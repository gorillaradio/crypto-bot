# Copiare in .env e riempire. Solo segreti e variabili di macchina.
# I parametri di progetto (capitale, fee, intervalli, finestre) stanno in config.toml.

# --- obbligatori ---
SECRET_KEY=            # firma della sessione; l'app rifiuta di partire senza (main.py:15)
ADMIN_PASSWORD=        # login della dashboard

# --- almeno una, secondo il provider usato ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# --- opzionali: variabili di macchina ---
# DATABASE_URL=postgresql+psycopg://crypto:crypto@localhost:5432/crypto
# SESSION_HTTPS_ONLY=false   # solo sviluppo locale su http
# APP_PORT=8000              # richiesto da docker-compose.prod.yml (porta pubblicata)
